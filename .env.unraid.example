# KampKollen — Unraid environment file
# Copy this file to .env in the same folder as docker-compose.unraid.yml
# Fill in your values. The .env file is read automatically by docker compose.

# Your Unraid server IP or hostname
FRONTEND_URL=http://YOUR_UNRAID_IP:7666

# Port exposed on your Unraid host
APP_PORT=7666

# Database password
DB_PASSWORD=change_this_db_password

# Auth secrets — must be at least 32 random characters each
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_random_32plus_char_string
COOKIE_SECRET=replace_with_another_random_32plus_char_string

# Azure AI image generation (from your Azure portal)
AZURE_AI_IMAGE_ENDPOINT=https://your-resource.services.ai.azure.com/mai/v1/images/generations?api-version=preview
AZURE_AI_IMAGE_API_KEY=your_azure_api_key_here
AZURE_AI_IMAGE_MODEL=MAI-Image-2e
AZURE_AI_IMAGE_API_VERSION=preview

# Set to true on first run to create admin account (safe to keep as true — skips if already seeded)
SEED_DB=true
