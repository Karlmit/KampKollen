generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  PLAYER
  SCOREKEEPER
  ADMIN
}

enum CompetitionStatus {
  DRAFT
  REGISTRATION
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ScoreType {
  number_highest_wins
  number_lowest_wins
  time_fastest_wins
  ranked_points
  placement_lowest_wins
  manual_points
  win_loss
  shooting
  least_time_difference
}

enum TeamScoreMode {
  sum_all_players
  best_n_players
  average_score
  manual_team_score
}

enum CompetitionScoringMode {
  raw_sum
  placement_points
}

enum TieBreakingMode {
  best_rank
  average
  worst_rank
}

model User {
  id              String     @id @default(cuid())
  username        String     @unique
  passwordHash    String?
  displayName     String?
  realName        String?
  profileImageUrl String?
  globalRole      GlobalRole @default(PLAYER)
  isDummy         Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  createdCompetitions Competition[]       @relation("CompetitionCreatedBy")
  competitionPlayers  CompetitionPlayer[]
  scores              Score[]             @relation("ScorePlayer")
  enteredScores       Score[]             @relation("ScoreEnteredBy")
  enteredTeamScores   TeamScore[]         @relation("TeamScoreEnteredBy")
  shots               Shot[]              @relation("ShotPlayer")
  enteredShots        Shot[]              @relation("ShotEnteredBy")
  teamLeaderships     Team[]              @relation("TeamLeader")
  trophies            Trophy[]            @relation("UserTrophies")
  groups              UserGroup[]
}

model Trophy {
  id                       String       @id @default(cuid())
  title                    String
  titleSv                  String?
  subtitle                 String?
  subtitleKey              String?
  subtitleParams           Json?
  imageUrl                 String
  userId                   String?
  user                     User?        @relation("UserTrophies", fields: [userId], references: [id])
  isOpened                 Boolean      @default(false)
  sentAt                   DateTime?
  groupId                  String?
  group                    Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  reservedForCompetitionId String?
  reservedForCompetition   Competition? @relation("TrophyReservation", fields: [reservedForCompetitionId], references: [id], onDelete: SetNull)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

model Competition {
  id              String                 @id @default(cuid())
  name            String
  date            DateTime?
  imageUrl        String?
  status          CompetitionStatus      @default(DRAFT)
  scoringMode          CompetitionScoringMode @default(raw_sum)
  placementMaxPoints   Int?
  tieBreakingMode      TieBreakingMode?
  isTeamCompetition    Boolean                @default(true)
  groupId         String?
  group           Group?                 @relation(fields: [groupId], references: [id])
  createdByUserId String
  createdByUser   User                   @relation("CompetitionCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  challenges       CompetitionChallenge[]
  teams            Team[]
  players          CompetitionPlayer[]
  scores           Score[]
  shots            Shot[]
  teamScores       TeamScore[]
  reservedTrophies Trophy[]               @relation("TrophyReservation")
}

model Challenge {
  id                   String        @id @default(cuid())
  name                 String
  description          String?
  logoUrl              String?
  scoreType            ScoreType     @default(number_highest_wins)
  defaultTeamScoreMode TeamScoreMode @default(sum_all_players)
  bestNPlayers         Int?
  shotsPerTeam         Int           @default(20)
  minShotsPerPlayer    Int           @default(3)
  maxScorePerShot      Int           @default(10)
  shootingLowerIsBetter Boolean      @default(false)
  // Unified "Attempts/Försök" mode config (scoreType = shooting). Defaults preserve
  // classic shooting behaviour; tweak these to get the Spike (cm, decimals, fixed
  // attempts, averaged team score) or any custom combination.
  valueUnit            String        @default("pts")
  allowDecimals        Boolean       @default(false)
  attemptsPerPlayer    Int?
  sumAllAttempts       Boolean       @default(false)
  useTeamScoreMode     Boolean       @default(false)
  // "Least time difference": what each of the two recorded times is called
  // (e.g. "promenad", "runda"). Free-text, admin-configurable.
  attemptLabel         String        @default("attempt")
  isGlobalTemplate     Boolean       @default(false)
  isQuiz               Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  competitionChallenges CompetitionChallenge[]
  quizQuestions         QuizQuestion[]
}

model CompetitionChallenge {
  id                    String        @id @default(cuid())
  competitionId         String
  competition           Competition   @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  challengeId           String
  challenge             Challenge     @relation(fields: [challengeId], references: [id])
  order                 Int           @default(0)
  scoreTypeOverride     ScoreType?
  teamScoreModeOverride TeamScoreMode?
  bestNPlayersOverride  Int?

  scores      Score[]
  shots       Shot[]
  teamScores  TeamScore[]
  quizSession QuizSession?

  @@unique([competitionId, challengeId])
}

model Team {
  id            String    @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  name          String
  imageUrl      String?
  leaderUserId  String?
  leader        User?     @relation("TeamLeader", fields: [leaderUserId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  players    CompetitionPlayer[]
  teamScores TeamScore[]
}

model CompetitionPlayer {
  id            String      @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  teamId        String?
  team          Team?       @relation(fields: [teamId], references: [id])
  isTeamLeader  Boolean     @default(false)
  isScorekeeper Boolean     @default(false)
  isQuizMaster  Boolean     @default(false)
  joinedAt      DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([competitionId, userId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Score {
  id                     String               @id @default(cuid())
  competitionId          String
  competition            Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  competitionChallengeId String
  competitionChallenge   CompetitionChallenge @relation(fields: [competitionChallengeId], references: [id], onDelete: Cascade)
  userId                 String
  player                 User                 @relation("ScorePlayer", fields: [userId], references: [id])
  rawScore               Float?
  timeMs                 Int?
  placement              Int?
  calculatedPoints       Float?
  enteredByUserId        String
  enteredByUser          User                 @relation("ScoreEnteredBy", fields: [enteredByUserId], references: [id])
  note                   String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([competitionChallengeId, userId])
}

// A single team-level result for "least time difference" (Time Walk) challenges.
// The team walks the same distance twice; the admin records both times and the
// team's score is the absolute difference between them (in seconds) — closest
// to zero wins. There is no per-player component, so this never touches the
// individual leaderboard.
model TeamScore {
  id                     String               @id @default(cuid())
  competitionId          String
  competition            Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  competitionChallengeId String
  competitionChallenge   CompetitionChallenge @relation(fields: [competitionChallengeId], references: [id], onDelete: Cascade)
  teamId                 String
  team                   Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  time1Ms                Int?
  time2Ms                Int?
  enteredByUserId        String
  enteredByUser          User                 @relation("TeamScoreEnteredBy", fields: [enteredByUserId], references: [id])
  note                   String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([competitionChallengeId, teamId])
  @@index([competitionChallengeId])
}

model Shot {
  id                     String               @id @default(cuid())
  competitionId          String
  competition            Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  competitionChallengeId String
  competitionChallenge   CompetitionChallenge @relation(fields: [competitionChallengeId], references: [id], onDelete: Cascade)
  userId                 String
  player                 User                 @relation("ShotPlayer", fields: [userId], references: [id])
  value                  Float
  order                  Int                  @default(0)
  enteredByUserId        String
  enteredByUser          User                 @relation("ShotEnteredBy", fields: [enteredByUserId], references: [id])
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([competitionChallengeId])
}

model Group {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  members      UserGroup[]
  competitions Competition[]
  trophies     Trophy[]
}

model UserGroup {
  userId  String
  groupId String
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

// ── Quiz ─────────────────────────────────────────────────────────────────────

enum QuizSessionStatus {
  LOBBY
  ACTIVE
  CORRECTING
  COMPLETED
}

model QuizQuestion {
  id           String    @id @default(cuid())
  challengeId  String
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  text         String
  imageUrl     String?
  points       Int       @default(1)
  order        Int       @default(0)
  timerSeconds Int       @default(0)
  isFreeText   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  options QuizOption[]
  answers QuizAnswer[]
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  imageUrl   String?
  isCorrect  Boolean      @default(false)
  order      Int          @default(0)

  answers QuizAnswer[]
}

model QuizSession {
  id                     String               @id @default(cuid())
  competitionChallengeId String               @unique
  competitionChallenge   CompetitionChallenge @relation(fields: [competitionChallengeId], references: [id], onDelete: Cascade)
  status                 QuizSessionStatus    @default(LOBBY)
  currentQuestionIndex   Int                  @default(0)
  questionLocked         Boolean              @default(false)
  correctionIndex        Int                  @default(0)
  correctAnswerVisible   Boolean              @default(false)
  lobbyAnnounced         Boolean              @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  readyEntries QuizReady[]
}

model QuizReady {
  id        String      @id @default(cuid())
  sessionId String
  session   QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  teamId    String?
  userId    String?

  @@unique([sessionId, teamId])
  @@unique([sessionId, userId])
}

model QuizAnswer {
  id             String       @id @default(cuid())
  questionId     String
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionId       String?
  option         QuizOption?  @relation(fields: [optionId], references: [id], onDelete: SetNull)
  freeTextAnswer String?
  freeTextPoints Int?
  freeTextLocked Boolean      @default(false)
  userId         String?
  teamId         String?
  submittedAt    DateTime     @default(now())

  @@unique([questionId, userId])
  @@unique([questionId, teamId])
}
